# Python Worker Environment Variables
# Set these in Render/Railway dashboard when deploying

# Secret key shared with Vercel for request authentication
# Generate with: openssl rand -hex 32
WORKER_SECRET=your-secret-key-here

# Path to arap_animate.py inside the container
RIG_PYTHON_SCRIPT=/app/arap_animate.py

# Python binary to use (inside container)
RIG_PYTHON_BIN=python3

# Port to listen on (Render/Railway will set this, keep as 8000)
PORT=8000
